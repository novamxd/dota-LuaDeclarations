{
  "include": ["**/*"],
  "compilerOptions": {
    "moduleResolution": "node",
    "noEmit": true,
    "target": "es2019",
    "lib": ["es2019"],
    "types": [],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
